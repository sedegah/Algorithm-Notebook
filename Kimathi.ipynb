# 1. Imports
%matplotlib inline
import random
import time
import copy
import matplotlib.pyplot as plt

plt.style.use('ggplot')
random.seed(42)

# 2. Linear Search
def linear_search(arr, target):
    for i, val in enumerate(arr):
        if val == target:
            return i
    return -1

# 3. Binary Search
def binary_search(arr, target):
    left, right = 0, len(arr)-1
    while left <= right:
        mid = (left + right)//2
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            left = mid + 1
        else:
            right = mid - 1
    return -1

# 4. Bubble Sort
def bubble_sort(arr):
    n = len(arr)
    for i in range(n):
        for j in range(0, n-i-1):
            if arr[j] > arr[j+1]:
                arr[j], arr[j+1] = arr[j+1], arr[j]
    return arr

# 5. Insertion Sort
def insertion_sort(arr):
    for i in range(1, len(arr)):
        key = arr[i]
        j = i-1
        while j >=0 and key < arr[j]:
            arr[j+1] = arr[j]
            j -= 1
        arr[j+1] = key
    return arr

# 6. Merge Sort
def merge_sort(arr):
    if len(arr) > 1:
        mid = len(arr)//2
        left = arr[:mid]
        right = arr[mid:]
        merge_sort(left)
        merge_sort(right)
        i = j = k = 0
        while i < len(left) and j < len(right):
            if left[i] < right[j]:
                arr[k] = left[i]
                i += 1
            else:
                arr[k] = right[j]
                j += 1
            k += 1
        while i < len(left):
            arr[k] = left[i]
            i += 1
            k += 1
        while j < len(right):
            arr[k] = right[j]
            j += 1
            k += 1
    return arr

# 7. Sizes
search_sizes = [10000, 20000, 40000, 80000]
sort_sizes = [2000, 5000, 10000, 20000]

linear_times = []
binary_times = []
bubble_times = []
insertion_times = []
merge_times = []

# 8. Benchmark Search
for n in search_sizes:
    data = sorted(random.sample(range(n*10), n))
    target = data[-1]

    start = time.time()
    linear_search(data, target)
    linear_times.append(time.time() - start)

    start = time.time()
    binary_search(data, target)
    binary_times.append(time.time() - start)

# 9. Benchmark Sorting
for n in sort_sizes:
    data = random.sample(range(n*10), n)

    arr_b = copy.deepcopy(data)
    start = time.time()
    bubble_sort(arr_b)
    bubble_times.append(time.time() - start)

    arr_i = copy.deepcopy(data)
    start = time.time()
    insertion_sort(arr_i)
    insertion_times.append(time.time() - start)

    arr_m = copy.deepcopy(data)
    start = time.time()
    merge_sort(arr_m)
    merge_times.append(time.time() - start)

# 10. Plot Search
plt.figure(figsize=(10,6))
plt.plot(search_sizes, linear_times, marker='o', label="Linear Search")
plt.plot(search_sizes, binary_times, marker='o', label="Binary Search")
plt.xlabel("Input Size (n)")
plt.ylabel("Runtime (seconds)")
plt.title("Search Algorithm Runtime Comparison")
plt.legend()
plt.show()

# 11. Plot Sorting
plt.figure(figsize=(10,6))
plt.plot(sort_sizes, bubble_times, marker='o', label="Bubble Sort")
plt.plot(sort_sizes, insertion_times, marker='o', label="Insertion Sort")
plt.plot(sort_sizes, merge_times, marker='o', label="Merge Sort")
plt.xlabel("Input Size (n)")
plt.ylabel("Runtime (seconds)")
plt.title("Sorting Algorithm Runtime Comparison")
plt.legend()
plt.show()

# 12.Discussion
print("DISCUSSION\n")

print("Search Algorithms:")
print("The results show that Linear Search exhibits a runtime that increases proportionally with input size,")
print("which is consistent with its O(n) time complexity. This occurs because the algorithm scans each element sequentially,")
print("and in this experiment, the target element was deliberately chosen as the last element to enforce the worst-case scenario.")
print()
print("In contrast, Binary Search demonstrates significantly slower growth in runtime, consistent with O(log n).")
print("This efficiency arises because the algorithm repeatedly halves the search space at each step,")
print("resulting in far fewer comparisons even as the dataset becomes large.")
print("The plot clearly shows Binary Search scaling much better than Linear Search.")
print()

print("Sorting Algorithms:")
print("In this experiment, a 'large collection of numbers' refers to increasing the number of elements (n) in the dataset,")
print("since algorithmic complexity depends primarily on input size rather than the magnitude of the values.")
print()
print("Bubble Sort and Insertion Sort both exhibit quadratic growth (O(n^2)), which is evident from the steep increase in runtime")
print("as the input size increases. As n grows, the number of operations increases dramatically, making these algorithms")
print("impractical for large datasets.")
print()
print("Merge Sort, on the other hand, shows significantly better performance, consistent with O(n log n).")
print("Its divide-and-conquer approach allows it to scale efficiently, which is reflected in the much flatter curve in the plot.")
print()
print("It is important to note that extremely large input sizes were avoided for Bubble Sort and Insertion Sort,")
print("as their quadratic growth leads to excessive runtimes (e.g., billions of operations for n ≥ 80,000).")
print("However, the observed trends clearly reflect the theoretical performance differences between the algorithms.")
print()

print("Conclusion:")
print("The experiment confirms that Binary Search and Merge Sort are far more efficient for large datasets.")
print("While Bubble Sort and Insertion Sort may be suitable for small or nearly sorted datasets,")
print("they become impractical as input size grows. Merge Sort provides the best overall performance,")
print("though it requires additional memory compared to the in-place sorting algorithms.")